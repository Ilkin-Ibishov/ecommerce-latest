{
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/store/dist/public",
  "installCommand": "pnpm install --ignore-scripts && pnpm rebuild esbuild",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
